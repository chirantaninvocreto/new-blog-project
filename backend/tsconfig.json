{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodeNext",
    "moduleResolution": "nodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
